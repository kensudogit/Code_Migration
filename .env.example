# PostgreSQL
# Default host port 5434 (5433 is often used by other local Postgres containers)
POSTGRES_PUBLISH_PORT=5434
DATABASE_URL=postgresql://codemig:codemig@localhost:5434/code_migration

# Web UI host port (container still listens on 3000)
WEB_PUBLISH_PORT=3001

# OpenAI Platform (optional ť mock mode when OPENAI_API_KEY is empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=
OPENAI_PROJECT=
OPENAI_BASE_URL=
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2
OPENAI_MAX_OUTPUT_TOKENS=16384

# Backend API
API_HOST=0.0.0.0
API_PORT=8090

# Next.js proxy target
API_URL=http://localhost:8090
