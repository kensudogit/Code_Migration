# Railway deploy — copy to service Variables (Dashboard or `railway variables set`)

# Required for real AI conversion (same name as OpenAI Platform dashboard)
OPENAI_API_KEY=sk-...

# Optional OpenAI Platform settings
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ORG_ID=
# OPENAI_PROJECT=

# PostgreSQL: add Railway Postgres plugin, then Reference ? DATABASE_URL on this service
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Set automatically in unified deploy (Dockerfile.unified / start-unified.sh)
# UNIFIED_DEPLOY=1
# API_URL=http://127.0.0.1:8091

# Next.js public URL (optional, for CORS/docs links)
# APP_PUBLIC_URL=https://your-app.up.railway.app
